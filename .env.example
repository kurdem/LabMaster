# =============================================================================
# LabMaster Docker-Host Bootstrap - Central Configuration
# =============================================================================
# Copy this file to ".env" and adjust the values to your environment.
# install.sh will copy it to ${DOCKER_ROOT}/.env automatically if missing.
#
# NOTE: Secrets (passwords, encryption keys) are NOT stored here. They are
# generated automatically into ${DOCKER_ROOT}/.secrets.env on first install.
# =============================================================================

# --- General ----------------------------------------------------------------
# Base domain. Services are reached as <subdomain>.${DOMAIN} via the proxy.
DOMAIN=example.com

# Timezone used by all containers (see: timedatectl list-timezones)
TIMEZONE=Europe/Berlin

# UID/GID used for bind-mounted data ownership (match your service user)
PUID=1000
PGID=1000

# --- Subdomains -------------------------------------------------------------
N8N_SUBDOMAIN=n8n
GITEA_SUBDOMAIN=git
SEMAPHORE_SUBDOMAIN=automation
DOCKHAND_SUBDOMAIN=dockhand

# --- Ports ------------------------------------------------------------------
# Caddy reverse proxy (public HTTP/HTTPS)
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Gitea SSH (host port mapped to container :22)
GITEA_SSH_PORT=2222

# --- Caddy / TLS / ACME -----------------------------------------------------
# Caddy terminates TLS automatically. TLS mode:
#   letsencrypt = real certificates via ACME (default)
#   internal    = self-signed via Caddy's internal CA (offline/homelab; browsers
#                 warn until you trust Caddy's root CA)
CADDY_TLS_MODE=letsencrypt

# ACME DNS provider (a caddy-dns/* plugin). Default "azure" uses the DNS-01
# challenge - no inbound ports/public reachability required, and wildcard-capable.
# Leave empty to use the HTTP/TLS-ALPN challenge instead (needs public DNS for
# each subdomain and reachable ports 80/443).
CADDY_DNS_PROVIDER=azure

# Go module compiled into the Caddy image (must match CADDY_DNS_PROVIDER). To use
# a different provider, set both this and CADDY_DNS_PROVIDER (e.g. cloudflare ->
# github.com/caddy-dns/cloudflare) and re-run update.sh to rebuild the image.
CADDY_DNS_MODULE=github.com/caddy-dns/azure

# E-mail for ACME registration (Let's Encrypt). Uncomment CADDY_ACME_CA to use
# the staging endpoint while testing (avoids rate limits; issues untrusted certs).
CADDY_ACME_EMAIL=admin@example.com
#CADDY_ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory

# Azure service-principal credentials for the DNS-01 challenge are SECRETS and
# live in ${DOCKER_ROOT}/.secrets.env (install.sh creates empty placeholders):
#   AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET,
#   AZURE_SUBSCRIPTION_ID, AZURE_RESOURCE_GROUP_NAME
# Leave tenant/client/secret empty to authenticate via a Managed Identity.

# --- Paths ------------------------------------------------------------------
# Root directory on the host for all Docker assets and data.
DOCKER_ROOT=/opt/docker

# --- Semaphore image --------------------------------------------------------
# Semaphore runs its tasks inside this container. PowerShell-capable images only
# exist as pinned tags (vX.Y.Z-powershellN.N.N); there is no rolling
# "latest-powershell" tag (plain "latest" has NO PowerShell). With
# SEMAPHORE_IMAGE_AUTO=1, install.sh/update.sh auto-resolve the newest STABLE
# -powershell tag from Docker Hub and write it here. Set SEMAPHORE_IMAGE_AUTO=0
# to pin SEMAPHORE_IMAGE_TAG manually (e.g. a non-PowerShell version).
SEMAPHORE_IMAGE_AUTO=1
SEMAPHORE_IMAGE_TAG=v2.18.12-powershell7.5.0

# --- Enabled stacks ---------------------------------------------------------
# Space-separated list of compose stacks to deploy (must match folder names
# under compose/). Add future services here (e.g. grafana prometheus ...).
STACKS="caddy gitea n8n semaphore dockhand"

# When 1 (default), install.sh/update.sh append newly shipped compose/<stack>
# folders to STACKS automatically (additive - stacks you removed stay removed,
# tracked via an auto-managed STACKS_KNOWN key). Set to 0 to manage STACKS by hand.
STACKS_AUTO=1

# --- Backup retention -------------------------------------------------------
# Number of backup archives to keep (older ones are pruned). 0 = keep all.
BACKUP_RETENTION=7
